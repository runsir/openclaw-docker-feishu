# ============================================
# OpenClaw 飞书插件 Docker 部署配置
# ============================================
# 复制此文件为 .env 并填入实际配置
# cp .env.example .env

# ===== Docker 配置 =====
# 项目名称
PROJECT_NAME=openclaw-feishu

# ===== 端口配置 =====
# SSH 映射端口（宿主机）
SSH_PORT=2222
# OpenClaw Gateway 端口（宿主机）
OPENCLAW_PORT=18789

# ===== OpenClaw Gateway 配置 =====
# 网关 Token，用于认证
OPENCLAW_GATEWAY_TOKEN=123456
# 网关绑定地址：lan（局域网）、local（本地）、all（所有）
OPENCLAW_GATEWAY_BIND=lan
# 网关端口（容器内部）
OPENCLAW_GATEWAY_PORT=18789
# Bridge 端口（容器内部）
OPENCLAW_BRIDGE_PORT=18790
# 网关模式：local、cloud
OPENCLAW_GATEWAY_MODE=local
# 允许的 Origin 域，多个用逗号隔开
OPENCLAW_GATEWAY_ALLOWED_ORIGINS=http://localhost,http://localhost:18789
# 允许不安全认证（如 http），可选 true/false
OPENCLAW_GATEWAY_ALLOW_INSECURE_AUTH=true
# 危险：禁用设备认证（如在 Docker 环境中无法获取设备信息），可选 true/false
OPENCLAW_GATEWAY_DANGEROUSLY_DISABLE_DEVICE_AUTH=false
# 插件全局控制
OPENCLAW_PLUGINS_ENABLED=true

# ===== 飞书官方插件配置 =====
# 飞书官方插件独立开关
# true  = 启用 feishu-openclaw-plugin
# false = 禁用 feishu-openclaw-plugin
FEISHU_OFFICIAL_PLUGIN_ENABLED=true

# ===== 飞书应用配置 =====
# 飞书应用 App ID（在飞书开放平台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
# 飞书应用 App Secret
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 飞书应用 Verification Token（用于验证回调）
FEISHU_VERIFICATION_TOKEN=
# 飞书应用 Encrypt Key（用于加密回调）
FEISHU_ENCRYPT_KEY=
# 消息回复模式：true=仅@回复, false=所有消息回复
FEISHU_REQUIRE_MENTION=true

# ===== 大模型配置（提供商 1 - 默认）=====
# 主模型 ID（支持多个，用逗号隔开，第一个将作为默认模型）
MODEL_ID=gpt-4o,gpt-4o-mini,gpt-3.5-turbo
# 图片模型 ID（可选，留空则使用 MODEL_ID，支持 provider/model 格式）
IMAGE_MODEL_ID=dall-e-3
# API Base URL（使用代理/国内源时配置）
BASE_URL=https://api.openai.com/v1
# API Key
API_KEY=sk-your-api-key-here
# API 协议类型: openai-completions 或 anthropic-messages
API_PROTOCOL=openai-completions
# 模型上下文窗口大小
CONTEXT_WINDOW=128000
# 模型最大输出 tokens
MAX_TOKENS=4096

# ===== 大模型配置（提供商 2 - 可选）=====
# MODEL2_NAME=Provider2
# MODEL2_MODEL_ID=model-id-1,model-id-2
# MODEL2_BASE_URL=http://xxxxx/v1
# MODEL2_API_KEY=123456
# MODEL2_PROTOCOL=openai-completions
# MODEL2_CONTEXT_WINDOW=200000
# MODEL2_MAX_TOKENS=8192

# ===== 阿里云百炼 API 配置（可选）=====
# 使用阿里云百炼大模型时配置
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 模型名称
# DASHSCOPE_MODEL=qwen-plus
# API Base URL
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== Claude 模型配置（可选）=====
# CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_BASE_URL=https://api.anthropic.com/v1

# ===== xAI Grok 配置（可选）=====
# XAI_API_KEY=xaixxxxxxxxxxxxxx
# XAI_MODEL=grok-2
# XAI_BASE_URL=https://api.x.ai/v1

# ===== 其他消息平台配置（可选，留空则不启用）=====
# Telegram 配置
# TELEGRAM_BOT_TOKEN=

# 钉钉配置
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=
# DINGTALK_ROBOT_CODE=
# DINGTALK_CORP_ID=
# DINGTALK_AGENT_ID=

# QQ 机器人配置
# QQBOT_APP_ID=
# QQBOT_CLIENT_SECRET=
# NapCat (OneBot v11) 配置
# NAPCAT_REVERSE_WS_PORT=
# NAPCAT_HTTP_URL=
# NAPCAT_ACCESS_TOKEN=
# NAPCAT_ADMINS=

# 企业微信配置
# WECOM_TOKEN=
# WECOM_ENCODING_AES_KEY=
# WECOM_BOTS_JSON=

# ===== 工作空间配置 =====
# 工作空间路径（容器内部）
WORKSPACE=/root/.openclaw/workspace
# 数据目录（挂载卷）
OPENCLAW_DATA_DIR=/root/.openclaw

# ===== 容器运行配置 =====
# 容器启动用户 UID:GID
# 默认 0:0（root）
# 如需与宿主机用户对齐，可设置为 1000:1000
OPENCLAW_RUN_USER=0:0

# ===== 自动升级配置 =====
# 是否启用自动升级：true=启用, false=禁用（默认）
AUTO_UPDATE=false
# 自动升级检查间隔（秒），默认 3600 秒（1小时）
UPDATE_CHECK_INTERVAL=3600

# ===== Skills 插件配置 =====
# 是否安装 ClawHub（Skills 管理工具，默认启用）
INSTALL_CLAWHUB=true
# 启动时安装的 Skills 列表（用逗号分隔）
# 可用 Skills: brave, coding-agent, web-search, github, filesystem, notion, slack, twitter 等
# 示例: SKILLS_LIST=brave,coding-agent,web-search,github
SKILLS_LIST=brave,web-search

# ===== 日志配置 =====
# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# ===== SSH 配置 =====
# SSH root 密码（首次配置后建议修改）
ROOT_PASSWORD=your-password-here
# SSH 内部端口
SSH_PORT_INTERNAL=22
