# ============================================
# OpenClaw 飞书插件 Docker 部署配置
# ============================================
# 复制此文件为 .env 并填入实际配置
# cp .env.example .env

# ===== 基础配置 =====
# 项目名称
PROJECT_NAME=openclaw-feishu

# ===== 端口配置 =====
# SSH 映射端口（宿主机）
SSH_PORT=2222
# OpenClaw Gateway 端口
OPENCLAW_PORT=18789

# ===== 飞书配置 =====
# 飞书应用 App ID（在飞书开放平台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
# 飞书应用 App Secret
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 飞书应用 Verification Token（用于验证回调）
FEISHU_VERIFICATION_TOKEN=
# 飞书应用 Encrypt Key（用于加密回调）
FEISHU_ENCRYPT_KEY=

# ===== OpenClaw Token 配置 =====
# OpenClaw API Token（用于认证和访问控制）
# 获取方式：在 OpenClaw Dashboard 或配置文件中生成
OPENCLAW_TOKEN=
# Token 类型：bearer 或 basic
OPENCLAW_TOKEN_TYPE=bearer

# ===== 大模型配置 =====
# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here
# OpenAI 模型（默认 gpt-4o）
OPENAI_MODEL=gpt-4o
# OpenAI API Base URL（使用代理/国内源时配置）
OPENAI_API_BASE=https://api.openai.com/v1

# ===== 阿里云百炼 API 配置（可选）=====
# 使用阿里云百炼大模型时配置
#DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 模型名称
#DASHSCOPE_MODEL=qwen-plus

# ===== Claude 模型配置（可选）=====
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ===== xAI Grok 配置（可选）=====
# XAI_API_KEY=
# XAI_MODEL=grok-2

# ===== OpenClaw 运行时配置 =====
# 消息回复模式：true=仅@回复, false=所有消息回复
FEISHU_REQUIRE_MENTION=true
# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# ===== 自动升级配置 =====
# 是否启用自动升级：true=启用, false=禁用（默认）
AUTO_UPDATE=false
# 自动升级检查间隔（秒），默认 3600 秒（1小时）
UPDATE_CHECK_INTERVAL=3600

# ===== Skills 插件配置 =====
# 是否安装 ClawHub（Skills 管理工具，默认启用）
INSTALL_CLAWHUB=true

# 启动时安装的 Skills 列表（用逗号分隔）
# 可用 Skills: brave, coding-agent, web-search, github, filesystem, notion, slack, twitter 等
# 示例: SKILLS_LIST=brave,coding-agent,web-search,github
SKILLS_LIST=brave,web-search

# ===== 网络配置 =====
# Docker 网络模式
NETWORK_MODE=bridge

# ===== SSH 配置 =====
# SSH root 密码（首次配置后建议修改）
ROOT_PASSWORD=your-password-here
# SSH 端口
SSH_PORT_INTERNAL=22
