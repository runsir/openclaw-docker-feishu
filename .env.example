# ============================================
# OpenClaw 飞书插件 Docker 部署配置
# ============================================
# 复制此文件为 .env 并填入实际配置
# cp .env.example .env

# ===== Docker 配置 =====
# 项目名称
PROJECT_NAME=openclaw-feishu

# ===== 端口配置 =====
# SSH 映射端口（宿主机）
SSH_PORT=2222
# OpenClaw Gateway 端口（宿主机）
OPENCLAW_PORT=18789

# ===== OpenClaw Gateway 配置 =====
# 网关 Token，用于认证
OPENCLAW_GATEWAY_TOKEN=123456
# 网关绑定地址：lan（局域网）、local（本地）、all（所有）
OPENCLAW_GATEWAY_BIND=lan
# 网关端口（容器内部）
OPENCLAW_GATEWAY_PORT=18789
# Bridge 端口（容器内部）
OPENCLAW_BRIDGE_PORT=18790
# 网关模式：local、cloud
OPENCLAW_GATEWAY_MODE=local
# 允许的 Origin 域，多个用逗号隔开
OPENCLAW_GATEWAY_ALLOWED_ORIGINS=http://localhost,http://localhost:18789
# 允许不安全认证（如 http），可选 true/false
OPENCLAW_GATEWAY_ALLOW_INSECURE_AUTH=true
# 危险：禁用设备认证（如在 Docker 环境中无法获取设备信息），可选 true/false
OPENCLAW_GATEWAY_DANGEROUSLY_DISABLE_DEVICE_AUTH=false
# 插件全局控制
OPENCLAW_PLUGINS_ENABLED=true

# ===== 飞书官方插件配置 =====
# 飞书官方插件独立开关
# true  = 启用 feishu-openclaw-plugin
# false = 禁用 feishu-openclaw-plugin
FEISHU_OFFICIAL_PLUGIN_ENABLED=true

# ===== 飞书应用配置 =====
# 飞书应用 App ID（在飞书开放平台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
# 飞书应用 App Secret
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 飞书应用 Verification Token（用于验证回调）
FEISHU_VERIFICATION_TOKEN=
# 飞书应用 Encrypt Key（用于加密回调）
FEISHU_ENCRYPT_KEY=
# 消息回复模式：true=仅@回复, false=所有消息回复
FEISHU_REQUIRE_MENTION=true

# ===== 大模型配置（提供商 1 - MiniMax - 优先推荐）=====
# 主模型 ID（MiniMax 编程相关模型）
# 可用模型: MiniMax-M2.5, MiniMax-M2.1, MiniMax-M2-Her, MiniMax-Text-01
MODEL_ID=MiniMax-M2.5,MiniMax-M2.1,MiniMax-M2-Her
# 图片模型 ID（可选，留空则使用 MODEL_ID，支持 provider/model 格式）
IMAGE_MODEL_ID=
# API Base URL
BASE_URL=https://api.minimaxi.com/v1
# API Key（从 https://platform.minimaxi.com 获取）
API_KEY=sk-your-minimax-api-key-here
# API 协议类型: openai-completions 或 anthropic-messages
API_PROTOCOL=openai-completions
# 模型上下文窗口大小（MiniMax-01 系列支持 400 万 token）
CONTEXT_WINDOW=128000
# 模型最大输出 tokens
MAX_TOKENS=4096

# ===== 大模型配置（提供商 2 - Kimi Moonshot - 第二优先）=====
MODEL2_NAME=Kimi
# Kimi 编程相关模型
# 可用模型: kimi-k2-turbo-preview, moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
MODEL2_MODEL_ID=kimi-k2-turbo-preview,moonshot-v1-128k
# API Base URL（与 OpenAI API 兼容）
MODEL2_BASE_URL=https://api.moonshot.cn/v1
# API Key（从 https://platform.moonshot.cn 获取）
MODEL2_API_KEY=sk-your-kimi-api-key-here
# API 协议类型
MODEL2_PROTOCOL=openai-completions
# 模型上下文窗口大小（moonshot-v1-128k 支持 128K）
MODEL2_CONTEXT_WINDOW=128000
# 模型最大输出 tokens
MODEL2_MAX_TOKENS=8192

# ===== 大模型配置（提供商 3 - 智谱 GLM - 第三优先）=====
MODEL3_NAME=智谱GLM
# 智谱编程相关模型
# 可用模型: glm-4, glm-4-coder, glm-4-long, glm-zero-preview, glm-z1-32b-0414
MODEL3_MODEL_ID=glm-4-coder,glm-4,glm-zero-preview
# API Base URL（与 OpenAI API 兼容）
MODEL3_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# API Key（从 https://open.bigmodel.cn/ 获取）
MODEL3_API_KEY=sk-your-zhipu-api-key-here
# API 协议类型
MODEL3_PROTOCOL=openai-completions
# 模型上下文窗口大小（glm-4-long 支持 128K）
MODEL3_CONTEXT_WINDOW=128000
# 模型最大输出 tokens
MODEL3_MAX_TOKENS=8192

# ===== 大模型配置（提供商 4 - OpenAI - 备选）=====
MODEL4_NAME=OpenAI
# OpenAI 模型
MODEL4_MODEL_ID=gpt-4o,gpt-4o-mini,gpt-3.5-turbo
# API Base URL
MODEL4_BASE_URL=https://api.openai.com/v1
# API Key（从 https://platform.openai.com 获取）
MODEL4_API_KEY=sk-your-openai-api-key-here
# API 协议类型
MODEL4_PROTOCOL=openai-completions
# 模型上下文窗口大小
MODEL4_CONTEXT_WINDOW=128000
# 模型最大输出 tokens
MODEL4_MAX_TOKENS=4096

# ===== 阿里云百炼 API 配置（可选）=====
# 使用阿里云百炼大模型时配置
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 模型名称
# DASHSCOPE_MODEL=qwen-plus
# API Base URL
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== Claude 模型配置（可选）=====
# CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_BASE_URL=https://api.anthropic.com/v1

# ===== xAI Grok 配置（可选）=====
# XAI_API_KEY=xaixxxxxxxxxxxxxx
# XAI_MODEL=grok-2
# XAI_BASE_URL=https://api.x.ai/v1

# ===== 多模态模型配置（图片、视频理解）=====
# 启用多模态功能：true=启用, false=禁用
MULTIMODAL_ENABLED=false

# 多模态模型提供商选择：minimax, kimi, zhipu, openai, claude
MULTIMODAL_PROVIDER=minimax

# ===== MiniMax 多模态配置 =====
# 视觉模型 ID
# MiniMax-VL-01（最新多模态视觉模型，支持 400 万 token 上下文）
MULTIMODAL_MINIMAX_MODEL_ID=MiniMax-VL-01
# MiniMax Base URL
MULTIMODAL_MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MiniMax API Key
MULTIMODAL_MINIMAX_API_KEY=sk-your-minimax-api-key-here

# ===== Kimi 多模态配置 =====
# Kimi 视觉模型 ID
# 可用模型: moonshot-v1-8k-vision-preview, moonshot-v1-32k-vision-preview, moonshot-v1-128k-vision-preview
MULTIMODAL_KIMI_MODEL_ID=moonshot-v1-128k-vision-preview
# Kimi Base URL
MULTIMODAL_KIMI_BASE_URL=https://api.moonshot.cn/v1
# Kimi API Key
MULTIMODAL_KIMI_API_KEY=sk-your-kimi-api-key-here

# ===== 智谱多模态配置 =====
# 智谱视觉模型 ID
# 可用模型: glm-4v（视觉语言模型）
MULTIMODAL_ZHIPU_MODEL_ID=glm-4v
# 智谱 Base URL
MULTIMODAL_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# 智谱 API Key
MULTIMODAL_ZHIPU_API_KEY=sk-your-zhipu-api-key-here

# ===== OpenAI 多模态配置 =====
# OpenAI 视觉模型 ID
# 可用模型: gpt-4o（原生多模态）, gpt-4o-mini, gpt-4-turbo
MULTIMODAL_OPENAI_MODEL_ID=gpt-4o
# OpenAI Base URL
MULTIMODAL_OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI API Key
MULTIMODAL_OPENAI_API_KEY=sk-your-openai-api-key-here

# ===== Claude 多模态配置 =====
# Claude 视觉模型 ID
# 可用模型: claude-3-5-sonnet-20241022, claude-3-5-opus-20241022
MULTIMODAL_CLAUDE_MODEL_ID=claude-3-5-sonnet-20241022
# Claude Base URL
MULTIMODAL_CLAUDE_BASE_URL=https://api.anthropic.com/v1
# Claude API Key
MULTIMODAL_CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ===== 多模态功能配置 =====
# 图片处理最大尺寸（像素），超出会自动压缩
# 默认 2048x2048，降低可节省 token 和费用
MULTIMODAL_MAX_IMAGE_SIZE=2048
# 图片质量：high（高清）, low（压缩）
MULTIMODAL_IMAGE_QUALITY=high
# 是否支持批量图片处理（一次对话发送多张图片）
MULTIMODAL_BATCH_IMAGES=true
# 批量处理最大图片数量
MULTIMODAL_MAX_BATCH_SIZE=5
# 是否启用视频理解（部分模型支持）
MULTIMODAL_VIDEO_UNDERSTANDING=false
# 视频最大时长（秒）
MULTIMODAL_MAX_VIDEO_DURATION=120

# ===== 多模态高级配置 =====
# 图片 OCR 文字提取：true=启用, false=禁用
MULTIMODAL_OCR_ENABLED=true
# 图片描述详细程度：brief（简短）, detailed（详细）, comprehensive（全面）
MULTIMODAL_DESCRIPTION_LEVEL=detailed
# 是否支持图片中代码识别和提取
MULTIMODAL_CODE_EXTRACTION=true
# 是否支持表格识别和结构化输出
MULTIMODAL_TABLE_EXTRACTION=true
# 多模态响应超时时间（秒）
MULTIMODAL_TIMEOUT=60

# ===== 其他消息平台配置（可选，留空则不启用）=====
# Telegram 配置
# TELEGRAM_BOT_TOKEN=

# 钉钉配置
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=
# DINGTALK_ROBOT_CODE=
# DINGTALK_CORP_ID=
# DINGTALK_AGENT_ID=

# QQ 机器人配置
# QQBOT_APP_ID=
# QQBOT_CLIENT_SECRET=
# NapCat (OneBot v11) 配置
# NAPCAT_REVERSE_WS_PORT=
# NAPCAT_HTTP_URL=
# NAPCAT_ACCESS_TOKEN=
# NAPCAT_ADMINS=

# 企业微信配置
# WECOM_TOKEN=
# WECOM_ENCODING_AES_KEY=
# WECOM_BOTS_JSON=

# ===== 工作空间配置 =====
# 工作空间路径（容器内部）
WORKSPACE=/root/.openclaw/workspace
# 数据目录（挂载卷）
OPENCLAW_DATA_DIR=/root/.openclaw

# ===== 容器运行配置 =====
# 容器启动用户 UID:GID
# 默认 0:0（root）
# 如需与宿主机用户对齐，可设置为 1000:1000
OPENCLAW_RUN_USER=0:0

# ===== 自动升级配置 =====
# 是否启用自动升级：true=启用, false=禁用（默认）
AUTO_UPDATE=false
# 自动升级检查间隔（秒），默认 3600 秒（1小时）
UPDATE_CHECK_INTERVAL=3600

# ===== Skills 插件配置 =====
# 是否安装 ClawHub（Skills 管理工具，默认启用）
INSTALL_CLAWHUB=true
# 启动时安装的 Skills 列表（用逗号分隔）
# 可用 Skills: brave, coding-agent, web-search, github, filesystem, notion, slack, twitter 等
# 示例: SKILLS_LIST=brave,coding-agent,web-search,github
SKILLS_LIST=brave,web-search

# ===== 日志配置 =====
# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# ===== SSH 配置 =====
# SSH root 密码（首次配置后建议修改）
ROOT_PASSWORD=your-password-here
# SSH 内部端口
SSH_PORT_INTERNAL=22
